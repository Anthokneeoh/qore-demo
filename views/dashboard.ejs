<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qore — Dashboard</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --green: #0B6E4F;
            --green-lt: #E6F5EE;
            --green-glow: #12A372;
            --bg: #F6F9F7;
            --card: #FFFFFF;
            --text: #0F1E16;
            --muted: #5A7566;
            --border: #D8E8E0;
            --accent: #F4A400;
            --red: #DC2626;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
        }
    </style>
</head>

<body>



    <div class="layout">
        <nav class="sidebar">
            <button class="sidebar-close" onclick="toggleMenu()">✕</button>
            <div class="nav-section" style="margin-top: 2rem;">Overview</div>
            <a class="nav-item active" onclick="showSection('overview', this)">Dashboard</a>
            <div class="nav-section">Data</div>
            <a class="nav-item" onclick="showSection('customers', this)">Customers</a>
            <a class="nav-item" onclick="showSection('accounts', this)">Accounts</a>
            <a class="nav-item" onclick="showSection('transfers', this)">Transactions</a>
            <div class="nav-section">Developer</div>
            <a class="nav-item" onclick="showSection('developer', this)">API Keys</a>
            <a class="nav-item" onclick="showSection('webhooks', this)">Webhooks</a>
        </nav>

        <main class="content">



            <!-- TRANSFERS -->
            <div id="section-transfers" style="display:none">
                <h1 class="page-title">Transactions</h1>
                <div class="card">
                    <div class="card-body" style="padding:0">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Amount (NGN)</th>
                                    <th>Destination</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>View</th>
                                    <th>Resend Webhook</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% transfers.forEach(t=> { %>
                                    <tr>
                                        <td class="mono">
                                            <%= t.id %>
                                        </td>

                                        <td class="amount-cell">
                                            <%= (t.amount/100).toLocaleString('en-NG',{minimumFractionDigits:2}) %>
                                        </td>

                                        <td class="mono">
                                            <%= t.destination_account_number || '–' %>
                                        </td>

                                        <td>
                                            <span class="status-pill s-<%= t.status %>">
                                                <%= t.status %>
                                            </span>
                                        </td>

                                        <td>
                                            <%= new Date(t.created_at).toLocaleDateString() %>
                                        </td>

                                        <td>
                                            <button class="btn btn-sm btn-ghost view-btn"
                                                data-tx='<%- JSON.stringify(t) %>'>
                                                View
                                            </button>
                                        </td>

                                        <td>
                                            <% const log=webhookLog.find(l=> l.transferId === t.id); %>
                                                <% if (log) { %>
                                                    <form method="POST"
                                                        action="/dashboard/resend-webhook/<%= log.webhookId %>"
                                                        style="display:inline">
                                                        <button type="submit" class="btn btn-sm btn-ghost">↺
                                                            Resend</button>
                                                    </form>
                                                    <% } else { %>
                                                        <span style="font-size:0.75rem;color:var(--muted)">No
                                                            webhook</span>
                                                        <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <dialog id="txModal">
        <h3>Transaction Details</h3>
        <p><strong>ID:</strong> <span id="modalId"></span></p>
        <p><strong>Status:</strong> <span id="modalStatusContainer"></span></p>
        <p><strong>Amount:</strong> <span id="modalAmount"></span></p>
        <p><strong>Source:</strong> <span id="modalSource"></span></p>
        <p><strong>Bank:</strong> <span id="modalBank"></span></p>
        <p><strong>Destination Account:</strong> <span id="modalDestAcct"></span></p>
        <p><strong>Destination Name:</strong> <span id="modalDestName"></span></p>
        <p><strong>Narration:</strong> <span id="modalNarration"></span></p>
        <button onclick="document.getElementById('txModal').close()">Close</button>
    </dialog>


    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const urlParams = new URLSearchParams(window.location.search);
            const targetTab = urlParams.get('tab');

            if (targetTab) {
                const navItem = document.querySelector(`.nav-item[data-tab="${targetTab}"]`);
                if (navItem) {
                    showSection(targetTab, navItem);
                }
            }

            document.querySelectorAll('.view-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    try {
                        const tx = JSON.parse(btn.dataset.tx);
                        openTxModal(tx);
                    } catch (e) {
                        console.error('Invalid transaction data', e);
                    }
                });
            });
        });

        function toggleMenu() {
            document.querySelector('.sidebar').classList.toggle('open');
        }

        function showSection(name, element) {
            document.querySelectorAll('[id^="section-"]').forEach(s => s.style.display = 'none');
            document.getElementById('section-' + name).style.display = 'block';
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            if (element) element.classList.add('active');

            if (window.innerWidth <= 768) {
                document.querySelector('.sidebar').classList.remove('open');
            }
        }

        function openTxModal(tx) {
            document.getElementById('modalId').textContent = tx.id;

            const statusSpan = document.createElement('span');
            statusSpan.className = `status-pill s-${tx.status}`;
            statusSpan.textContent = tx.status;

            const statusContainer = document.getElementById('modalStatusContainer');
            statusContainer.innerHTML = '';
            statusContainer.appendChild(statusSpan);

            document.getElementById('modalAmount').textContent =
                `NGN ${(tx.amount / 100).toLocaleString('en-NG', { minimumFractionDigits: 2 })}`;

            document.getElementById('modalSource').textContent = tx.source_account_id || '–';
            document.getElementById('modalBank').textContent = tx.destination_bank_code || '–';
            document.getElementById('modalDestAcct').textContent = tx.destination_account_number || '–';
            document.getElementById('modalDestName').textContent = tx.destination_account_name || '–';
            document.getElementById('modalNarration').textContent = tx.narration || '–';

            document.getElementById('txModal').showModal();
        }

        function copyKey(type, btn) {
            const input = document.getElementById('key-' + type);

            navigator.clipboard.writeText(input.value)
                .then(() => {
                    btn.textContent = 'copied!';
                    setTimeout(() => btn.textContent = 'copy', 2000);
                })
                .catch(() => {
                    alert('Copy failed. Please copy manually.');
                });
        }

        function copyWebhookUrl(btn) {
            const input = document.querySelector('.webhook-input');
            const feedback = document.getElementById('webhook-copy-feedback');

            navigator.clipboard.writeText(input.value)
                .then(() => {
                    btn.textContent = 'Copied!';
                    if (feedback) feedback.style.display = 'block';
                    setTimeout(() => {
                        btn.textContent = 'Copy';
                        if (feedback) feedback.style.display = 'none';
                    }, 2000);
                })
                .catch(() => {
                    alert('Copy failed. Please copy manually.');
                });
        }
    </script>
</body>

</html>