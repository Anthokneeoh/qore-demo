<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qore — Dashboard</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --green: #0B6E4F;
            --green-lt: #E6F5EE;
            --green-glow: #12A372;
            --bg: #F6F9F7;
            --card: #FFFFFF;
            --text: #0F1E16;
            --muted: #5A7566;
            --border: #D8E8E0;
            --accent: #F4A400;
            --red: #DC2626;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        .topbar {
            background: var(--card);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 990;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo {
            font-weight: 700;
            font-size: 1rem;
        }

        .logo span {
            color: var(--green-glow);
        }

        .menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text);
            padding: 0;
        }

        .sidebar-close {
            display: none;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text);
            position: absolute;
            top: 1.25rem;
            right: 1.5rem;
        }

        .sandbox-badge {
            background: rgba(244, 164, 0, 0.15);
            color: var(--accent);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
        }

        .layout {
            display: grid;
            grid-template-columns: 220px 1fr;
            min-height: calc(100vh - 56px);
        }

        .sidebar {
            background: var(--card);
            border-right: 1px solid var(--border);
            padding: 1.5rem 0;
        }

        .nav-item {
            display: block;
            padding: 0.5rem 1.5rem;
            font-size: 0.875rem;
            color: var(--muted);
            text-decoration: none;
            border-left: 3px solid transparent;
            cursor: pointer;
        }

        .nav-item:hover {
            color: var(--text);
            background: var(--bg);
        }

        .nav-item.active {
            color: var(--green);
            border-left-color: var(--green);
            background: var(--green-lt);
            font-weight: 600;
        }

        .nav-section {
            padding: 0.75rem 1.5rem 0.25rem;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-top: 1rem;
        }

        .content {
            padding: 2rem;
            overflow-y: auto;
        }

        .page-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 1.25rem;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .stat-num {
            font-size: 2rem;
            font-weight: 700;
            margin: 0.25rem 0;
        }

        .stat-sub {
            font-size: 0.75rem;
            color: var(--muted);
        }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }

        .card-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-title {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .card-body {
            padding: 1.25rem;
        }

        .key-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .key-type {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 0.15rem 0.5rem;
            border-radius: 4px;
            min-width: 40px;
            text-align: center;
        }

        .key-test {
            background: var(--green-lt);
            color: var(--green);
        }

        .key-live {
            background: #FEF3C7;
            color: #92400E;
        }

        .key-val {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.85rem;
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            flex: 1;
            color: var(--text);
        }

        .key-inactive {
            opacity: 0.5;
        }

        .btn {
            padding: 0.45rem 0.9rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.15s;
        }

        .btn-primary {
            background: var(--green);
            color: #fff;
        }

        .btn-primary:hover {
            background: var(--green-glow);
        }

        .btn-ghost {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--muted);
        }

        .btn-ghost:hover {
            color: var(--text);
            border-color: #aaa;
        }

        .btn-sm {
            padding: 0.3rem 0.65rem;
            font-size: 0.75rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        th {
            text-align: left;
            padding: 0.5rem 0.75rem;
            background: var(--bg);
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--muted);
            border-bottom: 2px solid var(--border);
        }

        td {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
        }

        .s-active {
            background: var(--green-lt);
            color: var(--green);
        }

        .s-pending {
            background: #FEF3C7;
            color: #92400E;
        }

        .s-success {
            background: var(--green-lt);
            color: var(--green);
        }

        .s-failed {
            background: #FEE2E2;
            color: var(--red);
        }

        .s-processing {
            background: #EFF6FF;
            color: #1D4ED8;
        }

        .mono {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.78rem;
        }

        .webhook-form {
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .webhook-input {
            flex: 1;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
            background: var(--bg);
        }

        .webhook-input:focus {
            outline: none;
            border-color: var(--green);
        }

        .feedback {
            font-size: 0.8rem;
            padding: 0.75rem 1rem;
            border-radius: 6px;
            margin-bottom: 1.5rem;
            font-weight: 500;
        }

        .feedback-ok {
            background: var(--green-lt);
            color: var(--green);
            border: 1px solid rgba(11, 110, 79, 0.2);
        }

        .feedback-err {
            background: #FEE2E2;
            color: var(--red);
            border: 1px solid rgba(220, 38, 38, 0.2);
        }

        .amount-cell {
            font-family: 'IBM Plex Mono', monospace;
        }

        dialog {
            border: none;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            padding: 0;
            width: 100%;
            max-width: 500px;
            margin: auto;
        }

        dialog::backdrop {
            background: rgba(0, 0, 0, 0.4);
        }

        .modal-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.75rem;
            font-size: 0.85rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px dashed var(--border);
        }

        .detail-label {
            color: var(--muted);
            font-weight: 500;
        }

        .detail-value {
            font-weight: 600;
        }

        .text-truncate {
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            display: inline-block;
            vertical-align: bottom;
        }

        .sn-col {
            color: var(--muted);
            font-size: 0.75rem;
            width: 30px;
            text-align: center;
        }

        /* Pagination controls */
        .pagination-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem;
            padding: 0.75rem 1.1rem;
            border-top: 1px solid var(--border);
            background: var(--bg);
            border-radius: 0 0 8px 8px;
            font-size: 0.8rem;
            color: var(--muted);
        }
        .pagination-bar form { display: inline-flex; align-items: center; gap: 0.4rem; }
        .pagination-bar select {
            border: 1px solid var(--border); border-radius: 5px;
            padding: 0.25rem 0.5rem; font-size: 0.78rem;
            background: var(--card); color: var(--text); cursor: pointer;
        }
        .pagination-bar .page-info { font-size: 0.78rem; color: var(--muted); }
        .pagination-nav { display: inline-flex; gap: 0.3rem; }
        .pagination-nav button {
            padding: 0.25rem 0.65rem; border-radius: 5px; font-size: 0.78rem;
            font-weight: 600; cursor: pointer; border: 1px solid var(--border);
            background: var(--card); color: var(--text); transition: all 0.15s;
        }
        .pagination-nav button:hover:not(:disabled) { background: var(--green-lt); border-color: var(--green); color: var(--green); }
        .pagination-nav button:disabled { opacity: 0.35; cursor: not-allowed; }

        @media (max-width: 768px) {
            .topbar {
                padding: 0 1rem;
            }

            .menu-toggle {
                display: block;
            }

            .layout {
                display: flex;
                flex-direction: column;
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: -100%;
                width: 280px;
                height: 100vh;
                z-index: 1000;
                transition: left 0.3s ease;
                display: block;
                box-shadow: 5px 0 15px rgba(0, 0, 0, 0.2);
                border-right: none;
            }

            .sidebar.open {
                left: 0;
            }

            .sidebar-close {
                display: block;
            }

            .nav-item {
                padding: 0.8rem 1.5rem;
                border-radius: 0;
            }

            .content {
                padding: 1rem;
            }

            .stats-row {
                grid-template-columns: 1fr;
                gap: 0.75rem;
            }

            .card-body {
                overflow-x: auto;
            }

            table {
                display: block;
                overflow-x: auto;
                white-space: nowrap;
            }

            .key-row {
                flex-wrap: wrap;
            }

            .key-val {
                min-width: 180px;
            }

            .webhook-form {
                flex-direction: column;
                align-items: stretch;
            }

            .webhook-input {
                width: 100%;
            }

            .btn-sm {
                padding: 0.3rem 0.6rem;
            }

            .pagination-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.75rem;
            }
        }
    </style>
</head>

<body>
    <div class="topbar">
        <div class="topbar-left">
            <button class="menu-toggle" onclick="toggleMenu()">☰</button>
            <div class="logo">Qore <span>Integration Hub</span></div>
        </div>
        <div style="display:flex;align-items:center;gap:1rem">
            <span class="sandbox-badge">SANDBOX</span>
            <a href="/" style="font-size:0.85rem;color:var(--muted);text-decoration:none">← API Docs</a>
        </div>
    </div>

    <div class="layout">
        <nav class="sidebar">
            <button class="sidebar-close" onclick="toggleMenu()">✕</button>
            <div class="nav-section" style="margin-top: 2rem;">Overview</div>
            <a class="nav-item active" data-tab="overview" onclick="showSection('overview', this)">Dashboard</a>

            <div class="nav-section">Data</div>
            <a class="nav-item" data-tab="customers" onclick="showSection('customers', this)">Customers</a>
            <a class="nav-item" data-tab="accounts" onclick="showSection('accounts', this)">Accounts</a>
            <a class="nav-item" data-tab="transfers" onclick="showSection('transfers', this)">Transactions</a>

            <div class="nav-section">Developer</div>
            <a class="nav-item" data-tab="developer" onclick="showSection('developer', this)">API Keys</a>
            <a class="nav-item" data-tab="webhooks" onclick="showSection('webhooks', this)">Webhooks</a>
        </nav>

        <main class="content">

            <div id="section-overview">
                <h1 class="page-title">Overview</h1>
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-label">Customers</div>
                        <div class="stat-num">
                            <%= customers.length %>
                        </div>
                        <div class="stat-sub">Registered entities</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Accounts</div>
                        <div class="stat-num">
                            <%= accounts.length %>
                        </div>
                        <div class="stat-sub">
                            <%= accounts.filter(a=>a.status==='active').length %> active
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Transactions</div>
                        <div class="stat-num">
                            <%= transfers.length %>
                        </div>
                        <div class="stat-sub">
                            <%= transfers.filter(t=>t.status==='success').length %> successful
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header"><span class="card-title">Recent Transactions</span></div>
                    <div class="card-body" style="padding:0">
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 30px; text-align: center;">#</th>
                                    <th>ID</th>
                                    <th>Amount</th>
                                    <th>Destination</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% transfers.slice(0, 5).forEach((t, index)=> {
                                    let destName = t.destination_customer_name || t.destination_account_name;
                                    if (!destName && t.destination_account_id) {
                                    const acct = accounts.find(a => a.id === t.destination_account_id);
                                    if (acct) {
                                    const cust = customers.find(c => c.id === acct.customer_id);
                                    if (cust) { destName = cust.first_name + ' ' + cust.last_name; }
                                    }
                                    }
                                    const isInternal = !!t.destination_account_id;
                                    %>
                                    <tr>
                                        <td class="sn-col">
                                            <%= index + 1 %>
                                        </td>
                                        <td class="mono">
                                            <%= t.id %>
                                        </td>
                                        <td class="amount-cell">NGN <%=
                                                (t.amount/100).toLocaleString('en-NG',{minimumFractionDigits:2}) %>
                                        </td>
                                        <td class="mono">
                                            <% if (isInternal) { %>
                                                <%= destName || t.destination_account_id %> <span
                                                        style="color:var(--muted);font-size:0.75rem">(Qore Bank)</span>
                                                    <% } else { %>
                                                        <%= t.destination_account_number || '–' %>
                                                            <% } %>
                                        </td>
                                        <td><span class="status-pill s-<%= t.status %>">
                                                <%= t.status %>
                                            </span></td>
                                        <td>
                                            <span style="white-space:nowrap;font-size:0.8rem;color:var(--muted)">
                                                <%= new Date(t.created_at).toLocaleString('en-GB', { day: 'numeric' ,
                                                    month: 'short' , year: 'numeric' , hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="section-customers" style="display:none">
                <h1 class="page-title">Customers</h1>
                <div class="card">
                    <div class="card-body" style="padding:0">
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 30px; text-align: center;">#</th>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Phone</th>
                                    <th>Email</th>
                                    <th>KYC Tier</th>
                                    <th>Status</th>
                                    <th>Date Registered</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% customers.forEach((c, index)=> { %>
                                    <tr>
                                        <td class="sn-col">
                                            <%= index + 1 %>
                                        </td>
                                        <td class="mono">
                                            <%= c.id %>
                                        </td>
                                        <td>
                                            <%= c.first_name %>
                                                <%= c.last_name %>
                                        </td>
                                        <td class="mono">
                                            <%= c.phone_number %>
                                        </td>
                                        <td>
                                            <%= c.email %>
                                        </td>
                                        <td style="text-align:center">
                                            <%= c.kyc_tier %>
                                        </td>
                                        <td><span class="status-pill s-active">active</span></td>
                                        <td>
                                            <span style="white-space:nowrap;font-size:0.8rem;color:var(--muted)">
                                                <%= new Date(c.created_at).toLocaleString('en-GB', { day: 'numeric' ,
                                                    month: 'short' , year: 'numeric' , hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-bar">
                        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
                            <span class="page-info">
                                Showing <%= ((cPage-1)*cLimit)+1 %> – <%= Math.min(cPage*cLimit, cCount) %> of <%= cCount %> customers
                            </span>
                            <form onsubmit="event.preventDefault(); goToPage('cpage','climit',1,this.climit.value)">
                                <label style="font-size:0.78rem">Per page:</label>
                                <select name="climit" onchange="goToPage('cpage','climit',1,this.value)">
                                    <option value="20"  <%= cLimit==20  ? 'selected' : '' %>>20</option>
                                    <option value="50"  <%= cLimit==50  ? 'selected' : '' %>>50</option>
                                    <option value="100" <%= cLimit==100 ? 'selected' : '' %>>100</option>
                                </select>
                            </form>
                        </div>
                        <div class="pagination-nav">
                            <button onclick="goToPage('cpage','climit',<%= cPage-1 %>,<%= cLimit %>)"
                                <%= cPage <= 1 ? 'disabled' : '' %>>← Prev</button>
                            <span class="page-info" style="padding:0.25rem 0.5rem">Page <%= cPage %> of <%= Math.max(1, Math.ceil(cCount/cLimit)) %></span>
                            <button onclick="goToPage('cpage','climit',<%= cPage+1 %>,<%= cLimit %>)"
                                <%= (cPage * cLimit) >= cCount ? 'disabled' : '' %>>Next →</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="section-accounts" style="display:none">
                <h1 class="page-title">Accounts</h1>
                <div class="card">
                    <div class="card-body" style="padding:0">
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 30px; text-align: center;">#</th>
                                    <th>ID</th>
                                    <th>Account No.</th>
                                    <th>Customer ID</th>
                                    <th>Product</th>
                                    <th>Currency</th>
                                    <th>Status</th>
                                    <th>Date Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% accounts.forEach((a, index)=> { %>
                                    <tr>
                                        <td class="sn-col">
                                            <%= index + 1 %>
                                        </td>
                                        <td class="mono">
                                            <%= a.id %>
                                        </td>
                                        <td class="mono">
                                            <%= a.account_number %>
                                        </td>
                                        <td class="mono">
                                            <%= a.customer_id %>
                                        </td>
                                        <td>
                                            <%= a.product_code.replace(/_/g, ' ' ) %>
                                        </td>
                                        <td>
                                            <%= a.currency %>
                                        </td>
                                        <td><span
                                                class="status-pill s-<%= a.status === 'active' ? 'active' : 'pending' %>">
                                                <%= a.status.replace(/_/g, ' ' ) %>
                                            </span></td>
                                        <td>
                                            <span style="white-space:nowrap;font-size:0.8rem;color:var(--muted)">
                                                <%= new Date(a.created_at).toLocaleString('en-GB', { day: 'numeric' ,
                                                    month: 'short' , year: 'numeric' , hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-bar">
                        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
                            <span class="page-info">
                                Showing <%= ((aPage-1)*aLimit)+1 %> – <%= Math.min(aPage*aLimit, aCount) %> of <%= aCount %> accounts
                            </span>
                            <form onsubmit="event.preventDefault(); goToPage('apage','alimit',1,this.alimit.value)">
                                <label style="font-size:0.78rem">Per page:</label>
                                <select name="alimit" onchange="goToPage('apage','alimit',1,this.value)">
                                    <option value="20"  <%= aLimit==20  ? 'selected' : '' %>>20</option>
                                    <option value="50"  <%= aLimit==50  ? 'selected' : '' %>>50</option>
                                    <option value="100" <%= aLimit==100 ? 'selected' : '' %>>100</option>
                                </select>
                            </form>
                        </div>
                        <div class="pagination-nav">
                            <button onclick="goToPage('apage','alimit',<%= aPage-1 %>,<%= aLimit %>)"
                                <%= aPage <= 1 ? 'disabled' : '' %>>← Prev</button>
                            <span class="page-info" style="padding:0.25rem 0.5rem">Page <%= aPage %> of <%= Math.max(1, Math.ceil(aCount/aLimit)) %></span>
                            <button onclick="goToPage('apage','alimit',<%= aPage+1 %>,<%= aLimit %>)"
                                <%= (aPage * aLimit) >= aCount ? 'disabled' : '' %>>Next →</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="section-transfers" style="display:none">
                <h1 class="page-title">Transactions</h1>
                <div class="card">
                    <div class="card-body" style="padding:0">
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 30px; text-align: center;">#</th>
                                    <th>ID</th>
                                    <th>Amount (NGN)</th>
                                    <th>Destination</th>
                                    <th>Status</th>
                                    <th>Direction</th>
                                    <th>Date</th>
                                    <th>View</th>
                                    <th>Resend Webhook</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% transfers.forEach((t, index)=> {
                                    let destName = t.destination_customer_name || t.destination_account_name;
                                    if (!destName && t.destination_account_id) {
                                    const acct = accounts.find(a => a.id === t.destination_account_id);
                                    if (acct) {
                                    const cust = customers.find(c => c.id === acct.customer_id);
                                    if (cust) { destName = cust.first_name + ' ' + cust.last_name; }
                                    }
                                    }
                                    const isInternal = !!t.destination_account_id;

                                    const txForModal = Object.assign({}, t);
                                    if (isInternal) {
                                    txForModal._resolvedBank = "Qore Bank";
                                    txForModal._resolvedName = destName;
                                    }

                                    const log = webhookLog.find(l => l && (l.transferId === t.id || l.transfer_id ===
                                    t.id || JSON.stringify(l).includes(t.id)));
                                    %>
                                    <tr>
                                        <td class="sn-col">
                                            <%= index + 1 %>
                                        </td>
                                        <td class="mono">
                                            <%= t.id %>
                                        </td>
                                        <td class="amount-cell">
                                            <%= (t.amount/100).toLocaleString('en-NG',{minimumFractionDigits:2}) %>
                                        </td>
                                        <td class="mono">
                                            <% if (isInternal) { %>
                                                <%= destName || t.destination_account_id %> <br><span
                                                        style="color:var(--muted);font-size:0.75rem">(Qore Bank)</span>
                                                    <% } else { %>
                                                        <%= t.destination_account_number || '–' %>
                                                            <% } %>
                                        </td>
                                        <td><span class="status-pill s-<%= t.status %>">
                                                <%= t.status %>
                                            </span></td>
                                        <td>
                                            <% if (isInternal) { %>
                                                <span class="status-pill"
                                                    style="background:#E0F2FE; color:#0369A1">Internal</span>
                                                <% } else { %>
                                                    <span class="status-pill"
                                                        style="background:#FEF3C7; color:#92400E">Outbound</span>
                                                    <% } %>
                                        </td>
                                        <td>
                                            <span style="white-space:nowrap;font-size:0.8rem;color:var(--muted)">
                                                <%= new Date(t.created_at).toLocaleString('en-GB', { day: 'numeric' ,
                                                    month: 'short' , year: 'numeric' , hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                            </span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-ghost view-btn"
                                                data-tx="<%= encodeURIComponent(JSON.stringify(txForModal)) %>">View</button>
                                        </td>
                                        <td>
                                            <% if (log) { %>
                                                <form method="POST"
                                                    action="/dashboard/resend-webhook/<%= log.webhookId || log.id %>"
                                                    style="display:inline">
                                                    <button type="submit" class="btn btn-sm btn-ghost">↺
                                                        Resend</button>
                                                </form>
                                                <% } else { %>
                                                    <span style="font-size:0.75rem;color:var(--muted)">No
                                                        webhook</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination-bar">
                        <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap">
                            <span class="page-info">
                                Showing <%= ((tPage-1)*tLimit)+1 %> – <%= Math.min(tPage*tLimit, tCount) %> of <%= tCount %> transactions
                            </span>
                            <form onsubmit="event.preventDefault(); goToPage('tpage','tlimit',1,this.tlimit.value)">
                                <label style="font-size:0.78rem">Per page:</label>
                                <select name="tlimit" onchange="goToPage('tpage','tlimit',1,this.value)">
                                    <option value="20"  <%= tLimit==20  ? 'selected' : '' %>>20</option>
                                    <option value="50"  <%= tLimit==50  ? 'selected' : '' %>>50</option>
                                    <option value="100" <%= tLimit==100 ? 'selected' : '' %>>100</option>
                                </select>
                            </form>
                        </div>
                        <div class="pagination-nav">
                            <button onclick="goToPage('tpage','tlimit',<%= tPage-1 %>,<%= tLimit %>)"
                                <%= tPage <= 1 ? 'disabled' : '' %>>← Prev</button>
                            <span class="page-info" style="padding:0.25rem 0.5rem">Page <%= tPage %> of <%= Math.max(1, Math.ceil(tCount/tLimit)) %></span>
                            <button onclick="goToPage('tpage','tlimit',<%= tPage+1 %>,<%= tLimit %>)"
                                <%= (tPage * tLimit) >= tCount ? 'disabled' : '' %>>Next →</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="section-developer" style="display:none">
                <h1 class="page-title">API Keys</h1>

                <% if (typeof query !=='undefined' && query.key_updated) { %>
                    <div class="feedback feedback-ok">✓ Test API Key regenerated successfully. Old key is revoked.</div>
                    <% } %>

                        <div class="card">
                            <div class="card-header">
                                <span class="card-title">Your keys</span>
                                <form method="POST" action="/dashboard/generate-key">
                                    <button type="submit" class="btn btn-ghost btn-sm">↺ Regenerate test key</button>
                                </form>
                            </div>
                            <div class="card-body">
                                <p style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem">
                                    Only <strong>test keys</strong> (sk_test_) work in this sandbox environment.
                                    Live keys are shown for reference only and will return 401.
                                </p>
                                <% apiKeys.forEach(k=> { %>
                                    <div class="key-row">
                                        <span class="key-type <%= k.type === 'test' ? 'key-test' : 'key-live' %>">
                                            <%= k.type %>
                                        </span>
                                        <input class="key-val <%= k.type !== 'test' ? 'key-inactive' : '' %>"
                                            id="key-<%= k.type %>" value="<%= k.key %>" readonly>
                                        <button class="btn btn-ghost btn-sm"
                                            onclick="copyKey('<%= k.type %>', this)">copy</button>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
            </div>

            <div id="section-webhooks" style="display:none">
                <h1 class="page-title">Webhook Settings</h1>

                <% if (typeof query !=='undefined' && query.saved) { %>
                    <div class="feedback feedback-ok">✓ Webhook URL saved successfully.</div>
                    <% } %>
                        <% if (typeof query !=='undefined' && query.resent) { %>
                            <div class="feedback feedback-ok">✓ Webhook payload resent successfully.</div>
                            <% } %>
                                <% if (typeof query !=='undefined' && query.error==='invalid_url' ) { %>
                                    <div class="feedback feedback-err">✗ Invalid URL — must start with http:// or
                                        https://</div>
                                    <% } %>

                                        <div class="card">
                                            <div class="card-header"><span class="card-title">Endpoint URL</span></div>
                                            <div class="card-body">
                                                <p style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem">
                                                    Qore sends <code>transfer.completed</code>,
                                                    <code>transfer.failed</code>, and
                                                    <code>account.activated</code> events to this URL.
                                                    Use <a href="https://webhook.site" target="_blank"
                                                        style="color:var(--green)">webhook.site</a> for testing.
                                                </p>
                                                <form method="POST" action="/dashboard/webhook" class="webhook-form">
                                                    <input type="url" name="url" class="webhook-input"
                                                        placeholder="https://webhook.site/your-unique-url"
                                                        value="<%= webhookUrl %>" pattern="https?://.*"
                                                        title="URL must start with http:// or https://" required>
                                                    <button type="submit" class="btn btn-primary">Save URL</button>
                                                    <% if (webhookUrl) { %>
                                                        <button type="button" class="btn btn-ghost"
                                                            id="copy-webhook-btn"
                                                            onclick="copyWebhookUrl(this)">Copy</button>
                                                        <% } %>
                                                </form>
                                                <div id="webhook-copy-feedback" class="feedback feedback-ok"
                                                    style="display:none; margin-top: 1rem; margin-bottom: 0;">✓ URL
                                                    copied to clipboard</div>
                                            </div>
                                        </div>

                                        <div class="card" style="margin-top:1.5rem">
                                            <div class="card-header"><span class="card-title">Recent delivery
                                                    attempts</span></div>
                                            <div class="card-body" style="padding:0">
                                                <% if (webhookLog.length===0) { %>
                                                    <div
                                                        style="padding:1.5rem;text-align:center;color:var(--muted);font-size:0.875rem">
                                                        No webhook deliveries yet. Initiate a transfer to generate
                                                        events.
                                                    </div>
                                                    <% } else { %>
                                                        <table>
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 30px; text-align: center;">#</th>
                                                                    <th>Event</th>
                                                                    <th>URL</th>
                                                                    <th>Status</th>
                                                                    <th>Date Attempted</th>
                                                                    <th>Resend</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% webhookLog.forEach((log, index)=> { %>
                                                                    <tr>
                                                                        <td class="sn-col">
                                                                            <%= index + 1 %>
                                                                        </td>
                                                                        <td class="mono">
                                                                            <%= log.event %>
                                                                        </td>
                                                                        <td class="mono"><span class="text-truncate"
                                                                                title="<%= log.url %>">
                                                                                <%= log.url %>
                                                                            </span></td>
                                                                        <td><span
                                                                                class="status-pill s-<%= log.status === 'delivered' ? 'success' : 'failed' %>">
                                                                                <%= log.status %>
                                                                            </span></td>
                                                                        <td>
                                                                            <span
                                                                                style="white-space:nowrap;font-size:0.8rem;color:var(--muted)">
                                                                                <%= new
                                                                                    Date(log.attemptedAt).toLocaleString('en-GB',
                                                                                    { day: 'numeric' , month: 'short' ,
                                                                                    year: 'numeric' , hour: '2-digit' ,
                                                                                    minute: '2-digit' }) %>
                                                                            </span>
                                                                        </td>
                                                                        <td>
                                                                            <form method="POST"
                                                                                action="/dashboard/resend-webhook/<%= log.webhookId %>"
                                                                                style="display:inline">
                                                                                <button type="submit"
                                                                                    class="btn btn-sm btn-ghost">↺
                                                                                    Resend</button>
                                                                            </form>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                            </tbody>
                                                        </table>
                                                        <% } %>
                                            </div>
                                        </div>
            </div>
        </main>
    </div>

    <dialog id="txModal" class="transaction-modal">
        <div class="modal-header">
            <h2>Transaction Details</h2>
            <button type="button" onclick="this.closest('dialog').close()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">✕</button>
        </div>
        <div class="modal-body">
            <div class="detail-row">
                <span class="detail-label">Transaction ID</span>
                <span class="detail-value mono" id="modal-id"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Amount</span>
                <span class="detail-value" id="modal-amount"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Destination</span>
                <span class="detail-value mono" id="modal-destination"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Bank</span>
                <span class="detail-value" id="modal-bank"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Status</span>
                <span class="detail-value" id="modal-status"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Reference</span>
                <span class="detail-value mono" id="modal-reference"></span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Initiated</span>
                <span class="detail-value" id="modal-date"></span>
            </div>
        </div>
    </dialog>

    <script>
        function toggleMenu() {
            const sidebar = document.querySelector('.sidebar');
            sidebar.classList.toggle('open');
        }

        function showSection(name, el) {
            document.querySelectorAll('[id^="section-"]').forEach(s => s.style.display = 'none');
            document.getElementById('section-' + name).style.display = 'block';
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            if (el) el.classList.add('active');
            // Update URL with active section without triggering a reload
            const url = new URL(window.location.href);
            url.searchParams.set('section', name);
            window.history.replaceState({}, '', url.toString());
        }

        function goToPage(pageParam, limitParam, pageVal, limitVal) {
            const url = new URL(window.location.href);
            url.searchParams.set(pageParam, pageVal);
            url.searchParams.set(limitParam, limitVal);
            // Preserve which section is currently visible
            const activeSection = document.querySelector('[id^="section-"][style*="block"]');
            if (activeSection) {
                url.searchParams.set('section', activeSection.id.replace('section-', ''));
            }
            window.location.href = url.toString();
        }

        document.querySelectorAll('.view-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const tx = JSON.parse(decodeURIComponent(this.dataset.tx));
                const modal = document.getElementById('txModal');

                document.getElementById('modal-id').textContent = tx.id;
                document.getElementById('modal-amount').textContent = 'NGN ' + (tx.amount / 100).toLocaleString('en-NG', { minimumFractionDigits: 2 });
                document.getElementById('modal-destination').textContent = tx._resolvedName || tx.destination_account_number || tx.destination_account_id || 'Unknown';
                document.getElementById('modal-bank').textContent = tx._resolvedBank || tx.destination_bank_name || tx.destination_bank_code || 'Unknown Bank';
                document.getElementById('modal-status').innerHTML = '<span class="status-pill s-' + tx.status + '">' + tx.status + '</span>';
                document.getElementById('modal-reference').textContent = tx.reference || 'N/A';
                document.getElementById('modal-date').textContent = new Date(tx.created_at).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });

                modal.showModal();
            });
        });

        function copyKey(type, btn) {
            const input = document.getElementById(`key-${type}`);
            input.select();
            document.execCommand('copy');
            btn.textContent = '✓ Copied';
            setTimeout(() => { btn.textContent = 'copy'; }, 1500);
        }

        function copyWebhookUrl(btn) {
            const input = document.querySelector('.webhook-input');
            input.select();
            document.execCommand('copy');
            document.getElementById('webhook-copy-feedback').style.display = 'block';
            setTimeout(() => { document.getElementById('webhook-copy-feedback').style.display = 'none'; }, 2000);
        }

        // On page load, restore the active section from URL param
        (function() {
            const params = new URLSearchParams(window.location.search);
            const section = params.get('section') || 'overview';
            const navEl = document.querySelector('.nav-item[onclick*="' + section + '"]');
            showSection(section, navEl);
        })();
    </script>
</body>

</html>
