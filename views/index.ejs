<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Qore Integration Hub — API Reference</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg: #FFFFFF;
            --bg-alt: #F6F9F7;
            --sidebar: #0D1F17;
            --text: #0F1E16;
            --muted: #5A7566;
            --border: #D8E8E0;
            --green: #0B6E4F;
            --green-lt: #E6F5EE;
            --green-glow: #12A372;
            --accent: #F4A400;
            --code-bg: #0D1F17;
            --code-text: #A8F0C6;
            --post: #12A372;
            --get: #0077CC;
            --radius: 8px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            flex-direction: column;
        }

        /* Sidebar */
        .sidebar {
            width: 100%;
            background: var(--sidebar);
            padding: 1rem;
            position: relative;
            height: auto;
            overflow-x: auto;
            white-space: nowrap;
            display: flex;
            gap: 1rem;
            scrollbar-width: thin;
        }

        .sidebar-logo {
            display: none;
            /* hide logo in mobile bar */
        }

        .nav-section {
            display: none;
            /* sections take space, hide on mobile */
        }

        .nav-link {
            display: inline-flex;
            padding: 0.4rem 0.8rem;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            font-size: 0.75rem;
            white-space: nowrap;
        }

        .nav-method {
            margin-right: 0.3rem;
        }

        /* Main content */
        .main {
            padding: 1rem;
            max-width: 100%;
            overflow-x: auto;
        }

        .hero h1 {
            font-size: 1.5rem;
        }

        .base-url {
            flex-wrap: wrap;
            word-break: break-all;
        }

        .cta-row {
            flex-direction: column;
            align-items: stretch;
            gap: 0.5rem;
        }

        .btn-primary,
        .btn-outline {
            text-align: center;
        }

        table {
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }

        .endpoint-header {
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .endpoint-body {
            padding: 0.75rem;
        }

        .subsection {
            margin-top: 1rem;
        }

        .code-block pre {
            font-size: 0.7rem;
        }

        .webhook-form {
            flex-direction: column;
            align-items: stretch;
        }

        .webhook-input {
            width: 100%;
        }

        .key-row {
            flex-wrap: wrap;
        }

        .key-val {
            min-width: 180px;
        }

        .stats-row {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .layout {
            grid-template-columns: 1fr;
        }

        .sidebar {
            display: flex;
            overflow-x: auto;
        }

        .nav-item {
            display: inline-block;
            white-space: nowrap;
        }

        /* For larger screens, revert to side by side */
        @media (min-width: 768px) {
            body {
                display: flex;
                flex-direction: row;
            }

            .sidebar {
                width: 260px;
                flex-direction: column;
                white-space: normal;
                display: block;
                position: sticky;
                top: 0;
                height: 100vh;
                overflow-y: auto;
                padding: 2rem 0;
            }

            .sidebar-logo {
                display: block;
            }

            .nav-section {
                display: block;
            }

            .nav-link {
                display: flex;
                background: transparent;
                border-radius: 0;
                padding: 0.45rem 1.5rem;
                white-space: normal;
            }

            .main {
                flex: 1;
                max-width: 900px;
                padding: 3rem 3rem 6rem;
            }

            .cta-row {
                flex-direction: row;
            }

            .stats-row {
                grid-template-columns: repeat(3, 1fr);
            }

            .layout {
                grid-template-columns: 220px 1fr;
            }

            .webhook-form {
                flex-direction: row;
            }
        }
    </style>
</head>

<body>

    <!-- Sidebar nav -->
    <nav class="sidebar">
        <div class="sidebar-logo">Qore <span>Integration Hub</span></div>
        <div class="nav-section">Getting Started</div>
        <a class="nav-link" onclick="scrollTo('auth')">Authentication</a>
        <a class="nav-link" onclick="scrollTo('errors')">Error Handling</a>
        <div class="nav-section">Endpoints</div>
        <a class="nav-link" onclick="scrollTo('customers-post')">
            <span class="nav-method nav-post">POST</span>/v1/customers
        </a>
        <a class="nav-link" onclick="scrollTo('customers-get')">
            <span class="nav-method nav-get">GET</span>/v1/customers
        </a>
        <a class="nav-link" onclick="scrollTo('accounts-post')">
            <span class="nav-method nav-post">POST</span>/v1/accounts
        </a>
        <a class="nav-link" onclick="scrollTo('name-enquiry')">
            <span class="nav-method nav-post">POST</span>/v1/transfers/name-enquiry
        </a>
        <a class="nav-link" onclick="scrollTo('transfers-post')">
            <span class="nav-method nav-post">POST</span>/v1/transfers
        </a>
        <a class="nav-link" onclick="scrollTo('transfers-get')">
            <span class="nav-method nav-get">GET</span>/v1/transfers
        </a>
        <a class="nav-link" onclick="scrollTo('transfers-id')">
            <span class="nav-method nav-get">GET</span>/v1/transfers/:id
        </a>
        <a class="nav-link" onclick="scrollTo('wallet')">
            <span class="nav-method nav-get">GET</span>/v1/wallet-balance
        </a>
    </nav>

    <!-- Main docs -->
    <main class="main">
        <div class="hero">
            <h1>Qore <span>API Reference</span></h1>
            <p>A standardized, self-serve API platform for African banking operations. Single base URL. RFC 9457 errors.
                Async payments with webhook delivery.</p>
            <div class="base-url">
                <span class="env-badge">SANDBOX</span>
                <span id="baseUrl">https://qore-demo.vercel.app</span>
                <button class="copy-btn" onclick="copyText('baseUrl', this)">copy</button>
            </div>
            <div class="cta-row">
                <a href="/dashboard/login" class="btn-primary">Get your API key →</a>
                <a href="/dashboard" class="btn-outline">View dashboard</a>
            </div>
        </div>

        <!-- AUTH -->
        <h2 class="section-title" id="auth">Authentication</h2>
        <div class="auth-card">
            <h3>Bearer token — all requests</h3>
            <div class="auth-header" id="authHeader">Authorization: Bearer sk_test_xxxxxxxxxxxxxx</div>
            <button class="copy-btn" style="margin-top:0.5rem" onclick="copyText('authHeader', this)">copy
                header</button>
            <p class="auth-note">
                Sandbox keys start with <code>sk_test_</code> — safe-to-fail, rate-limited to 100 req/min.
                Production keys (<code>sk_live_</code>) are inactive in sandbox and will return 401.
                Get your key from the <a href="/dashboard">developer dashboard</a>.
            </p>
        </div>

        <!-- ENDPOINTS -->
        <h2 class="section-title" id="customers-post">Customers</h2>

        <!-- POST /v1/customers -->
        <div class="endpoint-card">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge post-badge">POST</span>
                <span class="endpoint-path">/v1/customers</span>
                <span class="badge-tag">Idempotency-Key required</span>
                <span class="endpoint-desc">Create a customer entity</span>
            </div>
            <div class="endpoint-body open">
                <p>Creates the customer identity record. All subsequent operations (accounts, transfers) require a valid
                    <code>customer_id</code>. BVN, when provided, is validated asynchronously — customer creation
                    returns 201 immediately.
                </p>

                <div class="subsection">Request headers</div>
                <table>
                    <tr>
                        <th>Header</th>
                        <th>Value</th>
                        <th>Required</th>
                    </tr>
                    <tr>
                        <td><code>Authorization</code></td>
                        <td>Bearer sk_test_xxxxxx</td>
                        <td>Yes</td>
                    </tr>
                    <tr>
                        <td><code>Idempotency-Key</code></td>
                        <td>UUID v4</td>
                        <td>Yes</td>
                    </tr>
                    <tr>
                        <td><code>Content-Type</code></td>
                        <td>application/json</td>
                        <td>Yes</td>
                    </tr>
                </table>

                <div class="subsection">Request body</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "first_name":    "Amara",
  "last_name":     "Osei",
  "phone_number":  "+2348012345678",
  "email":         "amara.osei@example.com",
  "date_of_birth": "1990-04-15",
  "bvn":           "22412345678"
}</pre>
                </div>

                <div class="subsection">Response — 201 Created</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "id":           "cus_a1b2c3d4",
  "status":       "active",
  "first_name":   "Amara",
  "last_name":    "Osei",
  "phone_number": "+2348012345678",
  "email":        "amara.osei@example.com",
  "kyc_tier":     2,
  "created_at":   "2026-05-01T10:00:00Z"
}</pre>
                </div>

                <div class="subsection">Error response (with AI hint)</div>
                <div class="code-block">
                    <div class="code-label">400 Invalid Request <button class="copy-btn"
                            onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "type":       "https://api.qore.dev/errors/invalid-request",
  "title":      "Invalid Request",
  "status":     400,
  "detail":     "Phone number must be E.164 format for Nigeria: +234XXXXXXXXXX",
  "field":      "phone_number",
  "request_id": "req_a1b2c3d4",
  "timestamp":  "2026-05-01T10:00:00Z",
  "ai_hint":    "Nigerian numbers: remove the leading 0, add +234. Example: 08012345678 → +2348012345678"
}</pre>
                </div>

                <div class="try-section">
                    <h5>🧪 Try it in Postman</h5>
                    <p class="try-note">POST to <code>https://qore-demo.vercel.app/v1/customers</code> with header
                        <code>Your Authorization: Bearer sk_test_xxxxxx</code> and an <code>Idempotency-Key</code> UUID.
                        Try submitting <code>08012345678</code> (without +234) to see the AI hint in action.
                    </p>
                </div>
            </div>
        </div>

        <!-- GET /v1/customers -->
        <div class="endpoint-card" id="customers-get">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge get-badge">GET</span>
                <span class="endpoint-path">/v1/customers</span>
                <span class="endpoint-desc">List all customers</span>
            </div>
            <div class="endpoint-body">
                <p>Returns all customers for the authenticated institution. Supports optional filtering by
                    <code>email</code> or <code>phone</code> query params.
                </p>
                <div class="subsection">Query parameters</div>
                <table>
                    <tr>
                        <th>Parameter</th>
                        <th>Type</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td><code>email</code></td>
                        <td>string</td>
                        <td>Filter by exact email match</td>
                    </tr>
                    <tr>
                        <td><code>phone</code></td>
                        <td>string</td>
                        <td>Filter by exact phone number (E.164)</td>
                    </tr>
                </table>
                <div class="subsection">Response — 200 OK</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "data": [
    { "id": "cus_111", "first_name": "Amara", "last_name": "Osei", "kyc_tier": 2, "status": "active" }
  ],
  "meta": { "total_count": 1, "has_more": false }
}</pre>
                </div>
            </div>
        </div>

        <!-- POST /v1/accounts -->
        <h2 class="section-title" id="accounts-post">Accounts</h2>
        <div class="endpoint-card">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge post-badge">POST</span>
                <span class="endpoint-path">/v1/accounts</span>
                <span class="badge-tag">Idempotency-Key required</span>
                <span class="endpoint-desc">Provision a bank account</span>
            </div>
            <div class="endpoint-body">
                <p>Links a customer to a banking product and generates a 10-digit NUBAN account number. Account starts
                    as <code>pending_activation</code>. An <code>account.activated</code> webhook fires when KYC gate
                    clears (simulated after ~4 seconds for KYC tier 2+ customers).</p>
                <div class="subsection">Request body</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "customer_id":   "cus_a1b2c3d4",
  "product_code":  "SAVINGS_BASIC",
  "currency":      "NGN",
  "initial_deposit": 0
}</pre>
                </div>
                <div class="subsection">Response — 201 Created</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "id":             "acc_b2c3d4e5",
  "account_number": "3047291856",
  "status":         "pending_activation",
  "product_code":   "SAVINGS_BASIC",
  "currency":       "NGN",
  "customer_id":    "cus_a1b2c3d4",
  "created_at":     "2026-05-01T10:05:00Z"
}</pre>
                </div>
                <div class="subsection">Valid product codes</div>
                <table>
                    <tr>
                        <th>Code</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td><code>SAVINGS_BASIC</code></td>
                        <td>Basic savings account</td>
                    </tr>
                    <tr>
                        <td><code>SAVINGS_PREMIUM</code></td>
                        <td>Premium savings with higher limits</td>
                    </tr>
                    <tr>
                        <td><code>CURRENT</code></td>
                        <td>Current / business account</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Transfers -->
        <h2 class="section-title" id="name-enquiry">Transfers</h2>

        <!-- POST /v1/transfers/name-enquiry -->
        <div class="endpoint-card">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge post-badge">POST</span>
                <span class="endpoint-path">/v1/transfers/name-enquiry</span>
                <span class="badge-tag">Pre-condition</span>
                <span class="endpoint-desc">Verify destination account</span>
            </div>
            <div class="endpoint-body">
                <p>Must be called before initiating a transfer. Returns the account holder's name for end-user
                    confirmation — a fraud prevention requirement.</p>
                <div class="code-block">
                    <div class="code-label">Request body <button class="copy-btn"
                            onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "destination_bank_code":      "044",
  "destination_account_number": "0123456789"
}</pre>
                </div>
                <div class="code-block">
                    <div class="code-label">200 OK <button class="copy-btn" onclick="copyBlock(this)">copy</button>
                    </div>
                    <pre>{
  "account_name":   "Adeola Ogunlesi",
  "bank_name":      "Access Bank",
  "bank_code":      "044",
  "account_number": "0123456789",
  "verified_at":    "2026-05-01T10:09:00Z"
}</pre>
                </div>
            </div>
        </div>

        <!-- POST /v1/transfers -->
        <div class="endpoint-card" id="transfers-post">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge post-badge">POST</span>
                <span class="endpoint-path">/v1/transfers</span>
                <span class="badge-tag">Async · Webhook delivery</span>
                <span class="endpoint-desc">Initiate interbank transfer</span>
            </div>
            <div class="endpoint-body">
                <p>Returns <strong>202 Accepted</strong> immediately. Transfer is queued and processed asynchronously.
                    Final status is delivered via webhook (<code>transfer.completed</code> or
                    <code>transfer.failed</code>). Use GET /v1/transfers/:id to poll if webhooks are unavailable.
                </p>
                <p><strong>Amounts in kobo:</strong> 500000 = NGN 5,000.00</p>
                <div class="subsection">Request body</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "source_account_id":          "acc_111",
  "destination_bank_code":       "044",
  "destination_account_number":  "0123456789",
  "destination_account_name":    "Adeola Ogunlesi",
  "amount":                      500000,
  "currency":                    "NGN",
  "narration":                   "Invoice #INV-2026-001"
}</pre>
                </div>
                <div class="subsection">Response — 202 Accepted</div>
                <div class="code-block">
                    <div class="code-label">JSON <button class="copy-btn" onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "transfer_id":          "trf_c3d4e5f6",
  "status":               "processing",
  "amount":               500000,
  "currency":             "NGN",
  "estimated_settlement": "2026-05-01T10:12:00Z"
}</pre>
                </div>
                <div class="subsection">Webhook — transfer.completed</div>
                <div class="code-block">
                    <div class="code-label">Webhook payload <button class="copy-btn"
                            onclick="copyBlock(this)">copy</button></div>
                    <pre>{
  "event":      "transfer.completed",
  "webhook_id": "wh_d4e5f6g7",
  "timestamp":  "2026-05-01T10:10:30Z",
  "data": {
    "transfer_id":          "trf_c3d4e5f6",
    "status":               "success",
    "settlement_reference": "STL-1746091830000"
  }
}</pre>
                </div>
                <div class="subsection">Retry policy</div>
                表
                <tr>
                    <th>Attempt</th>
                    <th>Delay</th>
                    <th>Triggers on</th>
                </tr>
                <tr>
                    <td>1</td>
                    <td>Immediate</td>
                    <td>–</td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>15 seconds</td>
                    <td>5xx, 429, timeout</td>
                </tr>
                <tr>
                    <td>3</td>
                    <td>30 seconds</td>
                    <td>Same</td>
                </tr>
                <tr>
                    <td>4</td>
                    <td>60 seconds</td>
                    <td>Same</td>
                </tr>
                <tr>
                    <td>After 4</td>
                    <td>Dead letter queue</td>
                    <td>Manual replay in dashboard</td>
                </tr>
                </table>
                <p style="margin-top:0.5rem;font-size:0.8rem;color:var(--muted)">4xx responses from integrator endpoint
                    are NOT retried — a misconfigured handler will not self-heal.</p>
            </div>
        </div>

        <!-- GET /v1/transfers -->
        <div class="endpoint-card" id="transfers-get">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge get-badge">GET</span>
                <span class="endpoint-path">/v1/transfers</span>
                <span class="endpoint-desc">List all transfers</span>
            </div>
            <div class="endpoint-body">
                <p>Returns all transfers. Filter by <code>account_id</code> or <code>status</code>.</p>
                <div class="code-block">
                    <div class="code-label">200 OK <button class="copy-btn" onclick="copyBlock(this)">copy</button>
                    </div>
                    <pre>{
  "data": [ { "id": "trf_111", "status": "success", "amount": 500000, "currency": "NGN" } ],
  "meta": { "total_count": 1, "has_more": false }
}</pre>
                </div>
            </div>
        </div>

        <!-- GET /v1/transfers/:id -->
        <div class="endpoint-card" id="transfers-id">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge get-badge">GET</span>
                <span class="endpoint-path">/v1/transfers/:id</span>
                <span class="badge-tag">TSQ fallback</span>
                <span class="endpoint-desc">Poll transfer status</span>
            </div>
            <div class="endpoint-body">
                <p>Use when webhooks are unavailable. Poll every 60 seconds. After 5 polls with status
                    <code>processing</code>, escalate to support with the <code>transfer_id</code>.
                </p>
                <div class="code-block">
                    <div class="code-label">200 OK <button class="copy-btn" onclick="copyBlock(this)">copy</button>
                    </div>
                    <pre>GET /v1/transfers/trf_c3d4e5f6
→ { "id": "trf_c3d4e5f6", "status": "success", "settlement_reference": "STL-..." }</pre>
                </div>
            </div>
        </div>

        <!-- GET /v1/wallet-balance -->
        <h2 class="section-title" id="wallet">Wallet Balance</h2>
        <div class="endpoint-card">
            <div class="endpoint-header" onclick="toggleEndpoint(this)">
                <span class="method-badge get-badge">GET</span>
                <span class="endpoint-path">/v1/wallet-balance</span>
                <span class="endpoint-desc">Get account balance</span>
            </div>
            <div class="endpoint-body">
                <p>Returns available and ledger balance for a given account in kobo. Sandbox accounts start with NGN
                    100,000.00 seed balance.</p>
                <div class="code-block">
                    <div class="code-label">Request <button class="copy-btn" onclick="copyBlock(this)">copy</button>
                    </div>
                    <pre>GET /v1/wallet-balance?account_id=acc_111</pre>
                </div>
                <div class="code-block">
                    <div class="code-label">200 OK <button class="copy-btn" onclick="copyBlock(this)">copy</button>
                    </div>
                    <pre>{
  "account_id":                 "acc_111",
  "account_number":             "1029384756",
  "currency":                   "NGN",
  "available_balance":          9500000,
  "ledger_balance":             9500000,
  "available_balance_formatted": "NGN 95,000.00",
  "queried_at":                 "2026-05-01T10:15:00Z"
}</pre>
                </div>
            </div>
        </div>

        <!-- ERROR REFERENCE -->
        <h2 class="section-title" id="errors">Error Reference (RFC 9457)</h2>
        <div class="endpoint-card">
            <div class="endpoint-body open">
                <p>All errors use the RFC 9457 Problem Details format. Every error includes a <code>request_id</code>
                    for tracing. 4xx errors include an <code>ai_hint</code> field with a correction suggestion.</p>
                <table>
                    <tr>
                        <th>Status</th>
                        <th>Error type</th>
                        <th>When</th>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">400</td>
                        <td><code>invalid-request</code></td>
                        <td>Missing field, wrong type, format violation</td>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">401</td>
                        <td><code>unauthorized</code></td>
                        <td>Missing or invalid API key (sk_live_ in sandbox)</td>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">404</td>
                        <td><code>not-found</code></td>
                        <td>customer_id, account_id, or transfer_id not found</td>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">409</td>
                        <td><code>conflict</code></td>
                        <td>Duplicate email/phone or idempotency key collision</td>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">422</td>
                        <td><code>unprocessable</code></td>
                        <td>Business rule violation (frozen account, wrong product)</td>
                    </tr>
                    <tr class="error-row-4">
                        <td class="status-code s4xx">429</td>
                        <td><code>rate-limit-exceeded</code></td>
                        <td>100 req/min sandbox limit exceeded</td>
                    </tr>
                    <tr class="error-row-5">
                        <td class="status-code s5xx">503</td>
                        <td><code>service-unavailable</code></td>
                        <td>Downstream (NIBSS) unreachable — safe to retry</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="docs-footer">
            <p>Base URL: <code>https://qore-demo.vercel.app</code> &nbsp;|&nbsp; Sandbox:
                <code>https://qore-demo.vercel.app</code>
            </p>
            <p style="margin-top:0.5rem">TLS 1.2+ required on all requests &nbsp;|&nbsp; Idempotency keys stored 24h
                &nbsp;|&nbsp; Amounts in kobo (integer)</p>
        </div>
    </main>

    <script>
        function toggleEndpoint(header) {
            const body = header.nextElementSibling;
            body.classList.toggle('open');
        }

        function scrollTo(id) {
            const el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function copyText(id, btn) {
            const text = document.getElementById(id).textContent;
            navigator.clipboard.writeText(text.trim()).then(() => {
                btn.textContent = 'copied!';
                btn.classList.add('copied');
                setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 2000);
            });
        }

        function copyBlock(btn) {
            const pre = btn.closest('.code-block').querySelector('pre');
            navigator.clipboard.writeText(pre.textContent.trim()).then(() => {
                btn.textContent = 'copied!';
                btn.classList.add('copied');
                setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 2000);
            });
        }
    </script>
</body>

</html>